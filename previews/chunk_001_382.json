        "Heading": "alfavita: \u039d\u03ad\u03b1 \u03ba\u03b1\u03b9 \u03b5\u03b9\u03b4\u03ae\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03b7\u03bd \u0395\u03ba\u03c0\u03b1\u03af\u03b4\u03b5\u03c5\u03c3\u03b7 \u03b1\u03c0\u03cc \u03c4\u03bf \u03c0\u03c1\u03ce\u03c4\u03bf \u03b5\u03ba\u03c0\u03b1\u03b9\u03b4\u03b5\u03c5\u03c4\u03b9\u03ba\u03cc site \u03c3\u03c4\u03b7\u03bd \u0395\u03bb\u03bb\u03ac\u03b4\u03b1",
        "Abstract": "\u0395\u03b9\u03b4\u03ae\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u0395\u03ba\u03c0\u03b1\u03af\u03b4\u03b5\u03c5\u03c3\u03b7, \u03a0\u03b1\u03bd\u03b5\u03bb\u03bb\u03ae\u03bd\u03b9\u03b5\u03c2, \u03a5\u03c0\u03bf\u03c5\u03c1\u03b3\u03b5\u03af\u03bf \u03a0\u03b1\u03b9\u03b4\u03b5\u03af\u03b1\u03c2, \u0392\u03ac\u03c3\u03b5\u03b9\u03c2, \u03a3\u03c0\u03bf\u03c5\u03b4\u03ad\u03c2, \u0395\u03c1\u03b3\u03b1\u03c3\u03af\u03b1, \u0391\u03bd\u03b1\u03c0\u03bb\u03b7\u03c1\u03c9\u03c4\u03ad\u03c2, \u03a0\u03af\u03bd\u03b1\u03ba\u03b5\u03c2, \u0395\u03b9\u03b4\u03b9\u03ba\u03ae \u0391\u03b3\u03c9\u03b3\u03ae, \u03a0\u03c1\u03bf\u03c3\u03bb\u03ae\u03c8\u03b5\u03b9\u03c2, \u0388\u03ba\u03c4\u03b1\u03ba\u03c4\u03b7 \u0395\u03c0\u03b9\u03ba\u03b1\u03b9\u03c1\u03cc\u03c4\u03b7\u03c4\u03b1, \u039c\u03bf\u03c1\u03b9\u03bf\u03b4\u03cc\u03c4\u03b7\u03c3\u03b7",
