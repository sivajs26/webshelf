0440\u0430 \u043a\u0435\u0448 \u0448\u0430\u043d\u0441\u0430, \u043d\u0435 \u0432\u043b\u0435\u0433\u0443\u0432\u0430\u0430\u0442 \u0432\u043e \u043f\u0440\u0435\u0441\u043c\u0435\u0442\u043a\u0430 \u0437\u0430 \u043f\u043b\u0430\u0441\u043c\u0430\u043d.\n\u0414\u043e\u0431\u0438\u0442\u043d\u0438 \u0442\u0438\u043a\u0435\u0442\u0438 \u043e\u0434 \u0430\u043a\u0446\u0438\u0458\u0430\u0442\u0430 \u043a\u0435\u0448 \u0430\u0443\u0442, \u043d\u0435 \u0432\u043b\u0435\u0433\u0443\u0432\u0430\u0430\u0442 \u0432\u043e \u043f\u0440\u0435\u0441\u043c\u0435\u0442\u043a\u0430 \u0437\u0430 \u043f\u043b\u0430\u0441\u043c\u0430\u043d.\n\u041d\u0430\u0442\u043f\u0440\u0435\u0432\u0430\u0440\u0438\u0442\u0435 \u0442\u0438\u043f\u0443\u0432\u0430\u043d\u0438 \u0441\u043e \u0442\u0438\u043f\u043e\u0442 \u0410\u0437\u0438\u0441\u043a\u0438 \u0445\u0435\u043d\u0434\u0438\u043a\u0435\u043f \u043d\u0435 \u0432\u043b\u0435\u0433\u0443\u0432\u0430\u0430\u0442 \u0432\u043e \u043f\u0440\u0435\u0441\u043c\u0435\u0442\u043a\u0430.\n\u0421\u043f\u0435\u0446\u0438\u0458\u0430\u043b\u0438\u0442\u0435 \u0437\u0430 \u0438\u0441\u0442\u043e\u0438\u043c\u0435\u043d\u0430\u0442\u0430 \u043b\u0438\u0433\u0430 (\u0441\u0442\u0440\u0435\u043b\u0435\u0446, \u0443\u0434\u0430\u0440\u0438 \u043d\u0430 \u0433\u043e\u043b, \u043a\u043e\u0440\u043d\u0435\u0440\u0438, \u0436\u043e\u043b\u0442\u0438 \u043a\u0430\u0440\u0442\u043e\u043d\u0438 \u0438 \u0441\u043b \u043d\u0435 \u0432\u043b\u0435\u0433\u0443\u0432\u0430\u0430\u0442 \u0432\u043e \u043f\u0440\u0435\u0441\u043c\u0435\u0442\u043a\u0430).\n\u041c\u0438\u043d\u0438\u043c\u0443\u043c \u0443\u043f\u043b\u0430\u0442\u0430 \u0437\u0430 \u0443\u0447\u0435\u0441\u0442\u0432\u043e \u0432\u043e \u0430\u043a\u0446\u0438\u0441\u043a\u0430\u0442\u0430 \u043a\u0430\u043c\u043f\u0430\u045a\u0430 \u0435 50 \u0434\u0435\u043d\u0430\u0440\u0438.\n\u0417\u0430 \u0443\u0447\u0435\u0441\u0442\u0432\u043e \u0432\u043e \u0430\u043a\u0446\u0438\u0441\u043a\u0430\u0442\u0430 \u043a\u0430\u043c\u043f\u0430\u045a\u0430 \u0438 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0430 \u045c\u0435 \u0441\u0435 \u0437\u0435\u043c\u0430\u0442 \u0432\u043e \u043f\u0440\u0435\u0434\u0432\u0438\u0434 \u0441\u0430\u043c\u043e \u043f\u0440\u0432\u0438\u0442\u0435 5 \u0443\u043f\u043b\u0430\u0442\u0435\u043d\u0438 \u0442\u0438\u043a\u0435\u0442\u0438 \u0432\u043e \u0442\u0435\u043a\u043e\u0442 \u043d\u0430 \u0435\u0434\u0435\u043d \u0434\u0435\u043d.\n\u0412\u043e \u0430\u043a\u0446\u0438\u0458\u0430\u0442\u0430 \u0443\u0447\u0435\u0441\u0442\u0432\u0443\u0432\u0430\u0430\u0442 \u0442\u0438\u043a\u0435\u0442\u0438\u0442\u0435 \u043a\u043e\u0438 \u0448\u0442\u043e \u0441\u0435 \u0443\u043f\u043b\u0430\u0442\u0435\u043d\u0438 \u0432\u043e \u043f\u0435\u0440\u0438\u043e\u0434 \u043e\u0434 01.09.2025 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e 30.09.2025 \u0438 \u043d\u0430 \u043a\u043e\u0438 \u0448\u0442\u043e \u0438\u043c\u0430 \u043e\u0434\u0438\u0433\u0440\u0430\u043d\u043e \u043d\u0430\u0442\u043f\u0440\u0435\u0432\u0430\u0440\u0438 \u0438\u0441\u043a\u043b\u0443\u0447\u0438\u0432\u043e \u043e\u0434 \u0428\u043f\u0430\u043d\u0438\u0458\u0430 \u041b\u0430 \u041b\u0438\u0433\u0430 \u0438 \u0438\u0441\u0442\u0438\u0442\u0435 \u0441\u0435 \u0437\u0430\u0432\u0440\u0448\u0435\u043d\u0438\u00a0 \u0432\u043e \u043f\u0435\u0440\u0438\u043e\u0434 \u043e\u0434 01.09.2025 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e 30.09.2025, \u043e\u0434\u043d\u043e\u0441\u043d\u043e \u043e\u0434 \u043f\u0440\u0432\u0438\u043e\u0442 \u0434\u0435\u043d \u0432\u043e \u043c\u0435\u0441\u0435\u0446\u043e\u0442 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u043e\u0442 \u0434\u0435\u043d \u0432\u043e \u043c\u0435\u0441\u0435\u0446\u043e\u0442.\n\u0412\u043e \u0430\u043a\u0446\u0438\u0458\u0430\u0442\u0430 \u0443\u0447\u0435\u0441\u0442\u0432\u0443\u0432\u0430\u0430\u0442 \u0442\u0438\u043a\u0435\u0442\u0438\u0442\u0435 \u043a\u043e\u0438 \u0448\u0442\u043e \u0441\u0435 \u0443\u043f\u043b\u0430\u0442\u0435\u043d\u0438 \u0432\u043e \u043f\u0435\u0440\u0438\u043e\u0434 \u043e\u0434 01.10.2025 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e 31.10.2025 \u0438 \u043d\u0430 \u043a\u043e\u0438 \u0448\u0442\u043e \u0438\u043c\u0430 \u043e\u0434\u0438\u0433\u0440\u0430\u043d\u043e \u043d\u0430\u0442\u043f\u0440\u0435\u0432\u0430\u0440\u0438 \u0438\u0441\u043a\u043b\u0443\u0447\u0438\u0432\u043e \u043e\u0434 \u0418\u0442\u0430\u043b\u0438\u0458\u0430 \u0421\u0435\u0440\u0438\u0458\u0430 \u0410 \u0438 \u0438\u0441\u0442\u0438\u0442\u0435 \u0441\u0435 \u0437\u0430\u0432\u0440\u0448\u0435\u043d\u0438\u00a0 \u0432\u043e \u043f\u0435\u0440\u0438\u043e\u0434 \u043e\u0434 01.10.2025 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e 31.10.2025, \u043e\u0434\u043d\u043e\u0441\u043d\u043e \u043e\u0434 \u043f\u0440\u0432\u0438\u043e\u0442 \u0434\u0435\u043d \u0432\u043e \u043c\u0435\u0441\u0435\u0446\u043e\u0442 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u043e\u0442 \u0434\u0435\u043d \u0432\u043e \u043c\u0435\u0441\u0435\u0446\u043e\u0442.\n\u0412\u043e \u0430\u043a\u0446\u0438\u0458\u0430\u0442\u0430 \u0443\u0447\u0435\u0441\u0442\u0432\u0443\u0432\u0430\u0430\u0442 \u0442\u0438\u043a\u0435\u0442\u0438\u0442\u0435 \u043a\u043e\u0438 \u0448\u0442\u043e \u0441\u0435 \u0443\u043f\u043b\u0430\u0442\u0435\u043d\u0438 \u0432\u043e \u043f\u0435\u0440\u0438\u043e\u0434 \u043e\u0434 01.11.2025 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e 30.11.2025 \u0438 \u043d\u0430 \u043a\u043e\u0438 \u0448\u0442\u043e \u0438\u043c\u0430 \u043e\u0434\u0438\u0433\u0440\u0430\u043d\u043e \u043d\u0430\u0442\u043f\u0440\u0435\u0432\u0430\u0440\u0438 \u0438\u0441\u043a\u043b\u0443\u0447\u0438\u0432\u043e \u043e\u0434 \u0413\u0435\u0440\u043c\u0430\u043d\u0438\u0458\u0430 \u0411\u0443\u043d\u0434\u0435\u0441\u043b\u0438\u0433\u0430 \u0438 \u0438\u0441\u0442\u0438\u0442\u0435 \u0441\u0435 \u0437\u0430\u0432\u0440\u0448\u0435\u043d\u0438 \u0432\u043e \u043f\u0435\u0440\u0438\u043e\u0434 \u043e\u0434 01.11.2025 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e 30.11.2025, \u043e\u0434\u043d\u043e\u0441\u043d\u043e \u043e\u0434 \u043f\u0440\u0432\u0438\u043e\u0442 \u0434\u0435\u043d \u0432\u043e \u043c\u0435\u0441\u0435\u0446\u043e\u0442 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u043e\u0442 \u0434\u0435\u043d \u0432\u043e \u043c\u0435\u0441\u0435\u0446\u043e\u0442.\n\u0412\u043e \u0430\u043a\u0446\u0438\u0458\u0430\u0442\u0430 \u0443\u0447\u0435\u0441\u0442\u0432\u0443\u0432\u0430\u0430\u0442 \u0442\u0438\u043a\u0435\u0442\u0438\u0442\u0435 \u043a\u043e\u0438 \u0448\u0442\u043e \u0441\u0435 \u0443\u043f\u043b\u0430\u0442\u0435\u043d\u0438 \u0432\u043e \u043f\u0435\u0440\u0438\u043e\u0434 \u043e\u0434 01.12.2025 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e 31.12.2025 \u0438 \u043d\u0430 \u043a\u043e\u0438 \u0448\u0442\u043e \u0438\u043c\u0430 \u043e\u0434\u0438\u0433\u0440\u0430\u043d\u043e \u043d\u0430\u0442\u043f\u0440\u0435\u0432\u0430\u0440\u0438 \u0438\u0441\u043a\u043b\u0443\u0447\u0438\u0432\u043e \u043e\u0434 \u0410\u043d\u0433\u043b\u0438\u0458\u0430 \u041f\u0440\u0435\u043c\u0438\u0435\u0440 \u041b\u0438\u0433\u0430 \u0438 \u0438\u0441\u0442\u0438\u0442\u0435 \u0441\u0435 \u0437\u0430\u0432\u0440\u0448\u0435\u043d\u0438\u00a0 \u0432\u043e \u043f\u0435\u0440\u0438\u043e\u0434 \u043e\u0434 01.12.2025 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e 31.12.2025, \u043e\u0434\u043d\u043e\u0441\u043d\u043e \u043e\u0434 \u043f\u0440\u0432\u0438\u043e\u0442 \u0434\u0435\u043d \u0432\u043e \u043c\u0435\u0441\u0435\u0446\u043e\u0442 \u0437\u0430\u043a\u043b\u0443\u0447\u043d\u043e \u0441\u043e \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u043