        "Abstract": "\u0627\u0646\u0636\u0645 \u0625\u0644\u0649 \u0623\u0643\u0628\u0631 \u0645\u0646\u0635\u0629 \u0625\u0639\u0644\u0627\u0646\u0627\u062a \u0645\u0628\u0648\u0628\u0629 \u0641\u064a \u0645\u0635\u0631. \u062a\u0635\u0641\u062d \u0623\u0643\u062b\u0631 \u0645\u0646 200,000 \u0625\u0639\u0644\u0627\u0646 \u0644\u0633\u064a\u0627\u0631\u0627\u062a \u0645\u0633\u062a\u0639\u0645\u0644\u0629 \u0648\u0634\u0642\u0642 \u0644\u0644\u0628\u064a\u0639 \u0648\u0647\u0648\u0627\u062a\u0641 \u0645\u062d\u0645\u0648\u0644\u0629 \u0648\u0627\u0644\u0645\u0632\u064a\u062f. \u0627\u0634\u062a\u0631\u0650 \u0623\u0648 \u0628\u0639 \u0623\u064a \u0634\u064a\u0621 \u0639\u0644\u0649 \u062f\u0648\u0628\u064a\u0632\u0644 \u0627\u0644\u064a\u0648\u0645!",
