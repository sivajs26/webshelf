        "Abstract": "\u062f\u0627\u0645\u06d5\u0632\u0631\u0627\u0648\u06d5\u06cc \u0643\u0648\u0631\u062f\u0633\u062a\u0627\u0646 24 \u0628\u06c6 \u062a\u0648\u06ce\u0698\u06cc\u0646\u06d5\u0648\u06d5 \u0648 \u0631\u0627\u06af\u06d5\u06cc\u0627\u0646\u062f\u0646\u060c \u0646\u06ce\u0648\u06d5\u0646\u062f\u06ce\u0643\u06cc \u0645\u06cc\u062f\u06cc\u0627\u06cc\u06cc\u06d5. \u0628\u06ce\u0644\u0627\u06cc\u06d5\u0646\u0627\u0646\u06d5 \u0648 \u067e\u06cc\u0634\u06d5\u06cc\u06cc\u0627\u0646\u06d5\u060c \u0628\u06d5\u0631\u0647\u06d5\u0645\u06ce\u0643\u06cc \u067e\u0648\u062e\u062a\u06cc \u0645\u06cc\u062f\u06cc\u0627\u06cc\u06cc \u0628\u06d5 \u0634\u06ce\u0648\u06d5\u06cc\u06d5\u0643\u06cc \u067e\u0695\u06c6\u0641\u06cc\u0634\u0646\u0627\u06b5\u0627\u0646\u06d5 \u067e\u06ce\u0634\u0643\u06d5\u0634\u0649 \u0628\u06cc\u0646\u06d5\u0631 \u0648 \u0628\u06cc\u0633\u06d5\u0631 \u0648 \u062e\u0648\u06ce\u0646\u06d5\u0631\u0627\u0646\u06cc \u062f\u06d5\u0643\u0627\u062a \u0644\u06d5 \u0643\u0648\u0631\u062f\u0633\u062a\u0627\u0646 \u0648 \u0646\u0627\u0648\u0686\u06d5\u0643\u06d5 \u0648 \u062a\u06d5\u0648\u0627\u0648\u06cc \u062c\u06cc\u0647\u0627\u0646 \u0644\u06d5 \u0695\u06ce\u06af\u06d5\u06cc \u062a\u06c6\u0695\u06ce\u06a9\u06cc \u0645\u06cc\u062f\u06cc\u0627\u06cc\u06cc \u0631\u06ce\u06a9\u062e\u0631\u0627\u0648: \u0695\u0627\u062f\u06cc\u06c6\u060c \u062a\u06d5\u0644\u06d5\u06a4\u0632\u06cc\u06c6\u0646\u060c \u0626\u06d5\u067e\u06cc \u0645\u06c6\u0628\u0627\u06cc\u0644 \u0648 \u0648\u06cc\u0628\u0633\u0627\u06cc\u062a \u0628\u06d5 \u0632\u0645\u0627\u0646\u06d5\u0643\u0627\u0646\u06cc (\u0643\u0648\u0631\u062f\u06cc- \u06be\u06d5\u0631\u062f\u0648\u0648 \u0634\u06ce\u0648\u06d5\u0632\u0627\u0631\u06cc -\u06a9\u0631\u0645\u0627\u0646\u062c\u06cc \u0648 \u0633\u06c6\u0631\u0627\u0646\u06cc- \u0648 \u0626\u06cc\u0646\u06af\u0644\u06cc\u0632\u06cc\u060c \u0639\u06d5\u0631\u06d5\u0628\u06cc\u060c \u062a\u0648\u0631\u0643\u06cc \u0648 \u0641\u0627\u0631\u0633\u06cc) \u062f\u06d5\u06af\u0648\u0627\u0632\u06ce\u062a\u06d5\u0648\u06d5. \u0633\u06d5\u0631\u06d5\u0695\u0627\u06cc \u067e\u06d5\u06cc\u062c\u06d5\u06a9\u0627\u0646\u06cc \u06a9\u0648\u0631\u062f\u0633\u062a\u0627\u0646 24 \u0644\u06d5 \u062a\u06c6\u0695\u06d5 \u06a9\u06c6\u0645\u06d5\u06b5\u0627\u06cc\u06d5\u062a\u06cc\u06cc\u06d5\u06a9\u0627\u0646.",
